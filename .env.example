NODE_ENV=production
PORT=3000

# PostgreSQL connection string used by the backend container.
DATABASE_URL=postgres://viewwing_user:change_me@postgres:5432/viewwing_prod

# Replace with a long random secret for production.
JWT_SECRET=change_me_to_a_long_random_secret

# Comma-separated list of allowed frontend origins.
CORS_ORIGIN=https://1.162.142.236

LOG_LEVEL=info
LOG_TO_FILE=true
LOG_TO_CONSOLE=true
LOG_DIR=logs
LOG_FILE_NAME=app.log
ERROR_LOG_FILE_NAME=error.log

# Cloudflare R2 / S3-compatible storage, required only for media upload APIs.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
