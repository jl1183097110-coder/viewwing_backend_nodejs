{
  "name": "viewwing-backend",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.0",
  "scripts": {
    "dev": "dotenvx run -- tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "pnpm exec drizzle-kit migrate --config=drizzle.config.ts",
    "db:push": "pnpm exec drizzle-kit push --config=drizzle.config.ts",
    "db:check": "tsx src/scripts/checkDb.ts",
    "db:seed": "tsx src/scripts/seedData.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "@aws-sdk/s3-request-presigner": "^3.1009.0",
    "@dotenvx/dotenvx": "^1.52.0",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tsconfig/node-lts": "^24.0.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.2.2",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.28.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
